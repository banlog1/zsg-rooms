{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zsg-rooms-relay",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "durable_objects": {
    "bindings": [
      {
        "name": "ROOMS",
        "class_name": "RoomSession"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["RoomSession"]
    }
  ]
}
